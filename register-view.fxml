<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" alignment="CENTER" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demo6.RegisterController">
    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Регистрация" style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <Label text="Создайте новый аккаунт" />

    <Separator />

    <VBox spacing="15" alignment="CENTER">
        <TextField fx:id="regUsername" promptText="Имя пользователя (мин. 3 символа)" prefWidth="300" />
        <PasswordField fx:id="regPassword" promptText="Пароль (мин. 4 символа)" prefWidth="300" />
        <TextField fx:id="regEmail" promptText="Email" prefWidth="300" />
        <TextField fx:id="regFullName" promptText="Полное имя" prefWidth="300" />
        <TextField fx:id="regPhone" promptText="Номер телефона" prefWidth="300" />

        <Button text="Зарегистрироваться" onAction="#handleRegister" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;" prefWidth="200" />

        <Button text="← Назад к входу" onAction="#backToLogin" style="-fx-background-color: #9E9E9E; -fx-text-fill: white;" prefWidth="200" />
    </VBox>

    <Label fx:id="messageLabel" wrapText="true" />
</VBox>